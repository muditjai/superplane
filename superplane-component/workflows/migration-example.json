{
  "name": "superplane-migration-workflow",
  "description": "Example SuperPlane workflow: list ECS → deploy GCP → check Cloud Run",
  "steps": [
    {
      "id": "list_ecs",
      "component": "aws.lambda.runFunction",
      "config": {
        "functionName": "superplan-migration-list-ecs-tasks",
        "payload": {
          "cluster": "superplane-cluster",
          "service": "superplane-app"
        }
      }
    },
    {
      "id": "deploy_gcp",
      "component": "aws.lambda.runFunction",
      "config": {
        "functionName": "superplan-migration-deploy-to-gcp",
        "payload": "{{ steps.list_ecs.output.data.payload }}"
      }
    },
    {
      "id": "cloudrun_status",
      "component": "aws.lambda.runFunction",
      "config": {
        "functionName": "superplan-migration-get-cloudrun-status",
        "payload": "{{ steps.deploy_gcp.output.data.payload }}"
      }
    }
  ]
}
